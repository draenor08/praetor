# Praetor — environment template.
# Copy to `.env` and fill real values. `.env` is git-ignored; never commit it.

# --- PostgreSQL ---
POSTGRES_DB=praetor
POSTGRES_USER=praetor
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Backend (Spring Boot) ---
BACKEND_PORT=8080
# HS256 secret for signing JWTs — use a long random string in real .env
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_MIN=120

# --- Frontend (Angular) ---
FRONTEND_PORT=4200

# --- Judge sandbox ---
# Docker image used to compile/run submissions (no network, hard limits)
SANDBOX_IMAGE=praetor-judge:latest
# Per-submission resource ceilings (defaults; per-problem limits override in DB)
SANDBOX_CPU_SECONDS=2
SANDBOX_MEM_MB=256
SANDBOX_PIDS_MAX=64
# Number of concurrent judge workers
JUDGE_WORKERS=2
