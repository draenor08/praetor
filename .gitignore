# --- Secrets / env ---
.env
.env.local
*.env
!.env.example

# --- Java / Spring (backend) ---
target/
build/
*.class
*.jar
!**/gradle/wrapper/*.jar
.gradle/
hs_err_pid*

# --- Node / Angular (frontend) ---
node_modules/
dist/
.angular/
npm-debug.log*
yarn-error.log*

# --- IDE / editor ---
.idea/
.vscode/
*.iml
*.swp

# --- OS junk ---
.DS_Store
Thumbs.db

